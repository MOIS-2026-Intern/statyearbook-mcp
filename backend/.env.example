# 이 파일을 .env.local로 복사하고 선택한 채팅 provider의 키만 설정합니다.
# STATYEARBOOK_BACKEND_OPENAI_API_KEY=...
# main에서는 실제 frontend origin을 쉼표로 구분해 설정합니다.
# STATYEARBOOK_BACKEND_CORS_ORIGINS=https://statistics.example.go.kr
# 독립 배포된 app 서비스의 외부 또는 내부 MCP URL을 설정합니다.
# STATYEARBOOK_BACKEND_MCP_URL=https://mcp.example.go.kr/mcp
# STATYEARBOOK_BACKEND_BIZROUTER_API_KEY=...
# STATYEARBOOK_BACKEND_BIZROUTER_BASE_URL=https://api.bizrouter.ai/v1
# DEBUG, INFO, WARNING, ERROR, CRITICAL 중 하나를 사용합니다.
STATYEARBOOK_BACKEND_LOG_LEVEL=DEBUG
