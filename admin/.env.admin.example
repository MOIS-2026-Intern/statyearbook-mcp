# 관리자 앱은 기본적으로 loopback에서만 실행합니다.
STATYEARBOOK_ADMIN_HOST=127.0.0.1
STATYEARBOOK_ADMIN_PORT=8100
STATYEARBOOK_ADMIN_MAX_UPLOAD_MB=300

# 생략하면 루트 .env의 STATYEARBOOK_DSN을 로컬 검증 DB로 사용합니다.
# STATYEARBOOK_ADMIN_LOCAL_DSN=postgresql://USER:PASSWORD@localhost:5432/statyearbook_admin

# 외부 접속 또는 운영 배포 시 반드시 설정합니다.
# STATYEARBOOK_ADMIN_API_TOKEN=CHANGE_ME

# 운영 DB는 기본적으로 UI/API에서 비활성화됩니다.
STATYEARBOOK_ADMIN_ENABLE_PRODUCTION_TARGET=false
# STATYEARBOOK_ADMIN_PRODUCTION_DSN=postgresql://USER:PASSWORD@production:5432/statyearbook

STATYEARBOOK_ADMIN_BGE_MODEL_PATH=models/bge-m3
