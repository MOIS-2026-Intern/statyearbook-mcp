# 이 파일을 .env.local로 복사해 local profile 기본값을 덮어씁니다.
STATYEARBOOK_APP_DSN=postgresql:///statyearbook_mcp
STATYEARBOOK_APP_EMBED_PROVIDER=local
STATYEARBOOK_APP_LOG_LEVEL=DEBUG
# STATYEARBOOK_APP_EMBED_MODEL=/absolute/path/to/bge-m3
# Hugging Face로 전환할 때는 provider와 token만 덮어씁니다.
# STATYEARBOOK_APP_EMBED_PROVIDER=huggingface
# STATYEARBOOK_APP_HF_TOKEN=hf_...
# STATYEARBOOK_APP_HF_TIMEOUT_SECONDS=60
