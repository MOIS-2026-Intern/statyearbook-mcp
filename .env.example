# 이 파일은 "템플릿"입니다. 실제 값 없이 커밋됩니다.
# 사용법: cp .env.example .env  후 .env 에 진짜 값을 채워 넣으세요.
# .env 는 .gitignore 에 등록되어 커밋되지 않습니다.

# PostgreSQL 접속 문자열(DSN)
#   형식: postgresql://<사용자>:<비밀번호>@<호스트>:<포트>/<DB이름>
#   로컬 peer 인증이면: postgresql:///statyearbook_mcp
STATYEARBOOK_DSN=postgresql://USER:PASSWORD@localhost:5432/statyearbook_mcp

# 시각화 PNG 저장 경로. 상대 경로면 프로젝트 루트 기준입니다.
STATYEARBOOK_VISUALIZATION_DIR=outputs/visualizations

# 렌더링한 PNG를 HTTP로 서빙하는 정적 서버 바인딩(같은 머신에서만 도달 가능).
STATYEARBOOK_ASSET_HOST=127.0.0.1
STATYEARBOOK_ASSET_PORT=8899

# 공개 배포 시 이미지 링크 기준 URL. 설정하면 로컬 정적 서버 대신 이 값으로 링크를 만듭니다.
#   예: https://stats.example.com/viz
# STATYEARBOOK_PUBLIC_BASE_URL=

# OpenAI API 키 (임베딩 생성용: load/embed_statistics.py 에서 사용)
#   https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-...
