# 이 파일은 "템플릿"입니다. 실제 값 없이 커밋됩니다.
# 사용법: cp .env.example .env  후 .env 에 진짜 값을 채워 넣으세요.
# .env 는 .gitignore 에 등록되어 커밋되지 않습니다.

# PostgreSQL 접속 문자열(DSN)
#   형식: postgresql://<사용자>:<비밀번호>@<호스트>:<포트>/<DB이름>
#   로컬 peer 인증이면: postgresql:///statyearbook_mcp
STATYEARBOOK_DSN=postgresql://USER:PASSWORD@localhost:5432/statyearbook_mcp

# OpenAI API 키
#   - 채팅 provider가 openai이면 백엔드에서 사용
#   - OpenAI 임베딩을 선택한 관리자 작업에서도 사용
#   https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-...

# 검색 임베딩 provider
# 기본값은 기존 OpenAI text-embedding-3-small(1536차원)입니다.
STATYEARBOOK_EMBED_PROVIDER=openai
STATYEARBOOK_EMBED_MODEL=text-embedding-3-small
STATYEARBOOK_EMBED_DIMENSION=1536
STATYEARBOOK_EMBED_BATCH_SIZE=16
STATYEARBOOK_EMBED_MAX_LENGTH=512
# BGE-M3를 오프라인으로 사용할 때는 위 세 값을 다음처럼 변경합니다.
# STATYEARBOOK_EMBED_PROVIDER=local
# STATYEARBOOK_EMBED_MODEL=models/bge-m3
# STATYEARBOOK_EMBED_DIMENSION=1024
# STATYEARBOOK_EMBED_REVISION=5617a9f61b028005a4858fdac845db406aefb181
# STATYEARBOOK_EMBED_DEVICE=cpu
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# BizRouter를 사용할 때 필요한 서비스 API 키와 OpenAI 호환 endpoint
# BIZROUTER_API_KEY=sk-br-v1-...
# BIZROUTER_BASE_URL=https://api.bizrouter.ai/v1

# 채팅 백엔드
STATYEARBOOK_BACKEND_HOST=127.0.0.1
STATYEARBOOK_BACKEND_PORT=8000
STATYEARBOOK_BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STATYEARBOOK_MODEL_PROVIDER=openai
STATYEARBOOK_CHAT_MODEL=gpt-5.5
# BizRouter 사용 시 위 두 줄 대신 다음처럼 설정합니다.
# STATYEARBOOK_MODEL_PROVIDER=bizrouter
# STATYEARBOOK_CHAT_MODEL=openai/gpt-5.1
# STATYEARBOOK_MODEL_PROVIDER=local_gemma

# 백엔드가 stdio로 실행할 MCP 서버 명령.
# 기본값은 백엔드를 실행하는 Python 인터프리터와 server.py 입니다.
# STATYEARBOOK_MCP_COMMAND=/path/to/.venv/bin/python
# STATYEARBOOK_MCP_ARGS=server.py
# STATYEARBOOK_MCP_CWD=/path/to/statyearbook-mcp
